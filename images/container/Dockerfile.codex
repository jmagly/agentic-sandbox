# OpenAI Codex CLI agent image — layers `@openai/codex` on top of the
# shared dev toolchain (agent:dev). Node comes from agent:dev (fnm), so
# this image just installs the codex package itself.
#
# Build:
#   docker build -f images/container/Dockerfile.base  -t agentic/agent:base .
#   docker build -f images/container/Dockerfile.dev   -t agentic/agent:dev  .
#   docker build -f images/container/Dockerfile.codex -t agentic/codex .
#
# Issues: #175 (initial), #181 (parity epic), #184 (rebase to :dev)
FROM agentic/agent:dev

# `npm install -g` lands the binary in fnm's node prefix
# (/root/.local/share/fnm/...). Symlink it into /usr/local/bin so login
# shells (and `gh copilot`-style sessions) find it on PATH without any
# fnm shell-init magic.
# Pin tracked in ci/npm-pins.txt (issue #266).
# --ignore-scripts blocks lifecycle-script supply-chain attacks.
RUN npm install -g --ignore-scripts @openai/codex@0.130.0 \
 && ln -sf "$(npm prefix -g)/bin/codex" /usr/local/bin/codex \
 && codex --version
