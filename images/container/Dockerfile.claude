# Claude Code agent image — layers the Claude Code TUI on top of the
# shared dev toolchain (agent:dev). Operator session attaches land
# straight into `claude`; rg / fd / python / node / go / cargo are all
# already present from the dev layer.
#
# Build:
#   cd <repo-root>
#   docker build -f images/container/Dockerfile.base   -t agentic/agent:base .
#   docker build -f images/container/Dockerfile.dev    -t agentic/agent:dev  .
#   docker build -f images/container/Dockerfile.claude -t agentic/claude    .
#
# (`build.sh` does the chain in order for you.)
#
# Issues: #175 (initial), #181 (parity epic), #183 (rebase to :dev)
FROM agentic/agent:dev

# Node and curl come from agent:dev (fnm-managed Node, curl from apt).
# Installer needs bash; PATH already includes /root/.local/bin.
SHELL ["/bin/bash", "-c"]
RUN curl -fsSL https://claude.ai/install.sh | bash \
 && /root/.local/bin/claude --version || true

# Entrypoint inherited from base (tini → agent-entrypoint.sh → agent-client).
