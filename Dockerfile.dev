# Development Dockerfile for sandbox-manager
# Includes development tools and live reload support

FROM golang:1.22-alpine AS builder

# Install build dependencies
RUN apk add --no-cache \
    git \
    make \
    bash \
    ca-certificates

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum* ./

# Download dependencies
RUN go mod download

# Copy source code
COPY . .

# Build binaries
RUN make build

FROM alpine:latest

# Install runtime dependencies
RUN apk add --no-cache \
    ca-certificates \
    bash \
    curl \
    docker-cli \
    tini

# Create non-root user
RUN addgroup -g 1000 sandbox && \
    adduser -u 1000 -G sandbox -s /bin/bash -D sandbox

# Copy binaries from builder
COPY --from=builder /app/bin/sandbox-manager /usr/local/bin/
COPY --from=builder /app/bin/sandbox-cli /usr/local/bin/

# Create required directories
RUN mkdir -p /var/lib/sandbox/data /etc/sandbox/configs /etc/sandbox/agents && \
    chown -R sandbox:sandbox /var/lib/sandbox

# Switch to non-root user
USER sandbox

WORKDIR /app

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# Use tini for proper signal handling
ENTRYPOINT ["/sbin/tini", "--"]

CMD ["sandbox-manager"]
