  "defaultInputModes": ["text/plain", "application/json"],
  "defaultOutputModes": ["text/plain", "application/json"],
  "skills": [
    {
      "id": "sigma-hunt",
      "name": "Sigma rule hunting",
      "description": "Run Sigma rules against mounted log corpora.",
      "tags": ["security", "sigma", "container"]
