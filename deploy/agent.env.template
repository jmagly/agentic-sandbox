# Agentic Sandbox Agent Configuration
# Copy to /etc/agentic-sandbox/agent.env and fill in values

# Required: unique identifier for this agent
AGENT_ID=

# Required: shared secret for authentication (64 hex chars)
AGENT_SECRET=

# Required: management server address
MANAGEMENT_SERVER=host.internal:8120

# Optional: heartbeat interval in seconds (default: 30)
HEARTBEAT_INTERVAL=30

# Optional: agent profile name
AGENT_PROFILE=basic
