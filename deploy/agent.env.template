# Agentic Sandbox Agent Configuration
# Copy to /etc/agentic-sandbox/agent.env and fill in values

# Required: unique identifier for this agent
AGENT_ID=

# Optional legacy TCP authentication secret (64 hex chars).
# Secure transport provisioning omits this and uses AGENT_TRANSPORT plus
# AGENT_GRPC_TLS_* client material instead.
AGENT_SECRET=

# Required: management server address
MANAGEMENT_SERVER=host.internal:8120

# Optional: transport mode. New secure provisions should use auto with mTLS
# material; legacy provisions can leave this empty or use tcp.
AGENT_TRANSPORT=auto

# Optional: guest paths to gRPC mTLS client material.
AGENT_GRPC_TLS_CA=
AGENT_GRPC_TLS_CERT=
AGENT_GRPC_TLS_KEY=
AGENT_GRPC_TLS_SERVER_NAME=host.internal

# Optional: heartbeat interval in seconds (default: 30)
HEARTBEAT_INTERVAL=30

# Optional: agent profile name
AGENT_PROFILE=basic
