# Multi-stage build for management server
# Digest pinned per ci/digests.txt (issue #262).
FROM rust:1.88-bookworm@sha256:af306cfa71d987911a781c37b59d7d67d934f49684058f96cf72079c3626bfe0 AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    protobuf-compiler \
    libvirt-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy proto files and management server
COPY proto/ proto/
COPY management/ management/

WORKDIR /build/management
RUN cargo build --release --locked

# Runtime stage
# Digest pinned per ci/digests.txt (issue #262).
FROM debian:bookworm-slim@sha256:67b30a61dc87758f0caf819646104f29ecbda97d920aaf5edc834128ac8493d3

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    libvirt-clients \
    && rm -rf /var/lib/apt/lists/*

# Non-root runtime user (issue #262). UID 10001 is above the privileged range.
RUN groupadd --system --gid 10001 sandbox \
 && useradd  --system --uid 10001 --gid 10001 --home-dir /var/empty --shell /usr/sbin/nologin sandbox

# Secrets directory owned by sandbox so the runtime user can read/write.
RUN mkdir -p /tmp/secrets \
 && echo '{}' > /tmp/secrets/agent-hashes.json \
 && chown -R sandbox:sandbox /tmp/secrets \
 && chmod 700 /tmp/secrets

COPY --from=builder /build/management/target/release/agentic-mgmt /usr/local/bin/agentic-mgmt

ENV LISTEN_ADDR="0.0.0.0:8120"
ENV SECRETS_DIR="/tmp/secrets"

EXPOSE 8120 8121 8122

USER sandbox

ENTRYPOINT ["agentic-mgmt"]
