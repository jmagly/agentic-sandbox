# Agentic Sandbox management service configuration.
# Installed as /etc/agentic-sandbox/management.env.

# gRPC base listener. HTTP and WebSocket listeners derive consecutive ports.
# The default is loopback-only; set 0.0.0.0:8120 only with TLS/auth configured.
LISTEN_ADDR=127.0.0.1:8120

# Directory for agent secret hashes and runtime secret material.
SECRETS_DIR=/var/lib/agentic-sandbox/secrets

# Rust tracing filter.
RUST_LOG=info
