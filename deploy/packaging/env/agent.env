# Agentic Sandbox agent configuration.
# Installed as /etc/agentic-sandbox/agent.env.

AGENT_ID=
MANAGEMENT_SERVER=host.internal:8120
AGENT_TRANSPORT=auto

AGENT_GRPC_TLS_CA=
AGENT_GRPC_TLS_CERT=
AGENT_GRPC_TLS_KEY=
AGENT_GRPC_TLS_SERVER_NAME=host.internal

HEARTBEAT_INTERVAL=30
AGENT_PROFILE=basic
