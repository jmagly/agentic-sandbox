# Agentic Sandbox host runtime daemon configuration.
# Installed as /etc/agentic-sandbox/host-runtime.env.

AGENTIC_HOST_RUNTIME_DAEMON_SOCKET=/run/agentic-sandbox/host-runtime.sock
AGENTIC_HOST_RUNTIME_ROOT=/var/lib/agentic-sandbox/host-runtime
AGENTIC_HOST_GRPC_SERVER=127.0.0.1:50051
AGENTIC_HOST_AGENT_CLIENT=/usr/bin/agent-client
AGENTIC_HOST_SUPERVISOR_ID=host-supervisor-daemon
