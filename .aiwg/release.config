version: 1
project:
  name: agentic-sandbox
  display_name: Agentic Sandbox
  repo_url: https://git.integrolabs.net/roctinam/agentic-sandbox
  mirror_url: https://github.com/jmagly/agentic-sandbox
version_policy:
  format: calver
  pattern: 'YYYY.M.PATCH'
  tag_prefix: v
  channels:
    stable:
      tag_format: 'v{YYYY}.{M}.{PATCH}'
      require_changelog: true
      require_announcement: true
      require_uat: false
    rc:
      tag_format: 'v{YYYY}.{M}.{PATCH}-rc.{N}'
      require_changelog: true
      require_announcement: false
      require_uat: false
    nightly:
      tag_format: 'v{YYYY}.{M}.{PATCH}-nightly.{YYYYMMDD}'
      require_changelog: false
      require_announcement: false
      require_uat: false
gates:
  - name: local-build-test
    description: Local syntax, pin, formatting, and crate test checks before direct delivery.
    hard_stop: true
    steps:
      - run: bash -n scripts/bump-version.sh
      - run: bash -n scripts/run-e2e-tests.sh
      - run: bash -n scripts/verify-release-assets.sh
      - run: scripts/lint-ci-pins.sh
      - run: scripts/lint-npm-pins.sh
      - run: cargo fmt --manifest-path management/Cargo.toml --check
      - run: cargo fmt --manifest-path agent-rs/Cargo.toml --check
      - run: cargo fmt --manifest-path cli/Cargo.toml --check
      - run: cargo test --manifest-path management/Cargo.toml --lib
      - run: cargo test --manifest-path agent-rs/Cargo.toml --lib
      - run: cargo test --manifest-path cli/Cargo.toml --lib
  - name: doc-sync-code-to-docs
    description: Refresh documentation from the released code surface before cutting a tag.
    hard_stop: true
    invoke_skill: doc-sync
    args:
      direction: code-to-docs
      scope:
        - management
        - agent-rs
        - cli
        - scripts
        - images/qemu
        - docs
        - .aiwg
      dry_run_first: true
      write_report: true
  - name: changelog-and-release-notes
    description: Stable releases must include the changelog entry and operator-facing release notes.
    hard_stop: true
    required_for_channels:
      - stable
    artifacts:
      - path: CHANGELOG.md
        section_pattern: '## [{version}]'
      - path: 'docs/releases/v{version}.md'
        must_exist: true
  - name: ci-green
    description: Direct delivery requires the main branch and mirror workflows to be green before release completion.
    hard_stop: true
    tracker: gitea
    owner: roctinam
    repo: agentic-sandbox
    timeout_seconds: 2700
    poll_interval_seconds: 30
    required_workflows:
      - ci.yaml
      - conformance.yml
      - schema-lint.yml
      - supply-chain-lint.yml
  - name: release-tag
    description: Create and publish an annotated CalVer tag after direct-delivery changes land on main.
    hard_stop: true
    steps:
      - run: 'git tag -a {tag} -m "{tag}"'
      - run: git push origin {tag}
      - run: git push github {tag}
  - name: publication-verify
    description: Verify GitHub release assets and package surfaces after release automation publishes them.
    hard_stop: true
    steps:
      - run: scripts/verify-release-assets.sh {tag} --skip-ghcr
policy:
  delivery_mode: direct
  default_branch: main
  require_clean_worktree: true
  require_ci_green_before_done: true
  no_ai_attribution: true
  preserve_pre_release_announcements: false
  thank_external_reporters: true
publication_verify:
  github_repo: jmagly/agentic-sandbox
  ghcr_owner: jmagly
